# 开放端口
HTTP_PORT=3003

# Gin框架模式，生产环境请改为release
GIN_MODE=debug

# Socket.IO跨域设置，支持单个域名、*、或多个域名逗号分隔
SOCKET_CORS_ORIGIN=*
# 每个连接每秒发送消息速率（send_to_user/send_to_group）
SOCKET_SEND_RATE=40
# 令牌桶突发值（允许短时突发）
SOCKET_SEND_BURST=80

# MySQL DSN，示例: user:password@tcp(127.0.0.1:3306)/im_backend?charset=utf8mb4&parseTime=True&loc=Local
MYSQL_DSN=

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=im_backend
# Redis用户名，启用 ACL 时填写
REDIS_USERNAME=
